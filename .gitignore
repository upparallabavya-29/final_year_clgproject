# ─── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg

# ─── Virtual environments ─────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ─── Secrets / Config ────────────────────────────────────────────────────
.env
*.env.local
*.env.*.local

# ─── Model weights (large binary files — store on HuggingFace or DVC) ───
checkpoints/*.pth
checkpoints/*.pt
checkpoints/*.bin

# ─── Database (auto-generated at runtime) ────────────────────────────────
data/scan_history.db
data/*.db

# ─── Logs ─────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Contact form log (replaced by SQLite contacts table) ────────────────
contact_log.json

# ─── DB WAL transient files ───────────────────────────────────────────────
*.db-wal
*.db-shm

# ─── Eval results (auto-generated by evaluate.py) ────────────────────────
eval_results/

# ─── Install / smoke test artefacts (do not track) ───────────────────────
install_log.txt

# ─── Dataset (too large for git, download with download_data.py) ─────────
dataset/
data/images/

# ─── OS & IDE ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ─── Jupyter ──────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Testing artefacts ───────────────────────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
