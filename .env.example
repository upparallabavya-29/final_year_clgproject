# ══════════════════════════════════════════════════════════════════════════════
# CropGuard AI — Environment Configuration Example
# 
# Copy this file to `.env` and fill in the values before deploying to production.
# ══════════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────────
# Security & Authentication
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] JWT Secret Key. Must be a long, cryptographically secure random string.
# Generate one using: `openssl rand -hex 32` or `python -c "import secrets; print(secrets.token_hex(32))"`
SECRET_KEY=replace_this_with_a_secure_random_string_in_production

# [REQUIRED] Algorithm for JWT. Recommended: HS256
ALGORITHM=HS256

# [REQUIRED] Expiration time for access tokens in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours


# ──────────────────────────────────────────────────────────────────────────────
# System URLs & Networking
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Frontend URL constraint. Used for CORS and OAuth redirects.
# Local Development: http://localhost:5173
# Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173


# ──────────────────────────────────────────────────────────────────────────────
# Google OAuth Integration (Optional)
# ──────────────────────────────────────────────────────────────────────────────
# If these are left blank, the "Continue with Google" button will show an error.
# You must create an OAuth Client ID in the Google Cloud Console.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback


# ──────────────────────────────────────────────────────────────────────────────
# Model Configurations (Optional)
# ──────────────────────────────────────────────────────────────────────────────

# Path to weights relative to the project root
VIT_MODEL_PATH=checkpoints/vit_plant_disease.pth
SWIN_MODEL_PATH=checkpoints/swin_plant_disease.pth


# ──────────────────────────────────────────────────────────────────────────────
# Database Configurations (Optional)
# ──────────────────────────────────────────────────────────────────────────────

# The default SQLite path is `data/scan_history.db`.
# To override this, uncomment and set the connection string:
# DATABASE_URL=sqlite:///./data/scan_history.db

# ──────────────────────────────────────────────────────────────────────────────
# Twilio SMS Config (Optional)
# ──────────────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
